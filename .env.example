# ============================================================
# MIGRON — Environment Variables Template
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below.
# 3. NEVER commit .env to version control.
# ============================================================

# ── Firebase (Client-side, VITE_ prefix) ─────────────────────
# All 6 required. Find them in:
# Firebase Console → Project Settings → Your Apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — enables Google Analytics (Firebase measurementId)
VITE_FIREBASE_MEASUREMENT_ID=

# ── Site Identity ─────────────────────────────────────────────
# Canonical domain — used in SEO tags, JSON-LD schema, and sitemap.
VITE_SITE_URL=https://migron.mtive.tech

# ── Groq AI (Server-side only — Vercel Function) ─────────────
# Used exclusively in api/chat.js (never bundled into the browser).
# Get your key at: https://console.groq.com → API Keys
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ── External API base URLs (optional overrides) ───────────────
# Defaults are built into src/config/api.ts.
# Override only if you need to point at a proxy or test server.
# VITE_FRANKFURTER_API_URL=https://api.frankfurter.dev/v1
# VITE_COINGECKO_API_URL=https://api.coingecko.com/api/v3
# VITE_GOLD_API_URL=https://api.gold-api.com/price

# ── Optional / Future Integrations ───────────────────────────
# Uncomment and fill in when you activate these services.

# Weather data — https://openweathermap.org/api
# VITE_OPENWEATHER_API_KEY=

# Air quality index — https://aqicn.org/data-platform/token/
# VITE_WAQI_API_KEY=

# Windy webcam widget — https://api.windy.com
# VITE_WINDY_WEBCAMS_KEY=

# NSW Open Data (Transport) — https://opendata.transport.nsw.gov.au
# VITE_NSW_TRANSPORT_API_KEY=
